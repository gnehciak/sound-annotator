rules_version = '2';

// Each project document is private to its owner. The app queries projects with
// `where('ownerId', '==', uid)`, which these rules permit; any attempt to read
// or write someone else's project is denied.
service cloud.firestore {
  match /databases/{database}/documents {
    match /projects/{projectId} {
      allow read: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;

      // Owner can edit/delete; ownerId can never be reassigned to someone else.
      allow update: if request.auth != null
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == request.auth.uid;

      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }
  }
}

rules_version = '2';

// Each project document is private to its owner. The app queries projects with
// `where('ownerId', '==', uid)`, which these rules permit; any attempt to read
// or write someone else's project is denied.
//
// Exception: a project flagged `shared == true` can be fetched *by its id* by
// anyone holding the link (the unguessable random doc id is the share token),
// with no sign-in. This powers the read-only `?view={id}` link. A project
// flagged `editableByLink == true` can additionally be *edited* by any
// signed-in user holding the link — content fields only, one session at a
// time (see the edit lock below). Only the owner can flip either flag (see
// the update rule), so a project is never exposed without its owner's say.
//
// `get` and `list` are split on purpose: a stranger may fetch a single shared
// doc by id, but only the owner may *query* the collection. Without this split a
// `where('shared','==',true)` query would let anyone enumerate every shared
// project — turning unlisted links into a public directory.
service cloud.firestore {
  match /databases/{database}/documents {
    match /projects/{projectId} {
      // ---- edit lock (see src/lib/editLock.ts) --------------------------
      // One person edits at a time. The lock is a `lock` map on the doc —
      // { sessionId, uid, name, at } — refreshed by a heartbeat while its
      // holder is editing. These rules make it a *hard* lock: a session that
      // lost the lock (stale tab, taken over) has its content writes refused,
      // so it can't clobber the current editor's notes.

      // A lock is live while its heartbeat is fresher than 40s. (Clients
      // treat a lock as stale at 45s, so they never claim one these rules
      // still consider live.)
      function lockLive(lock) {
        return lock != null
          && lock.at is timestamp
          && lock.at > request.time - duration.value(40, 's');
      }

      // A free or expired lock gates nothing (pre-lock app versions keep
      // saving). A *live* lock demands the content write prove it's the
      // holder: it must carry a claim for the same session AND refresh it
      // (`at` is a server timestamp, so a genuine holder's save always
      // changes the lock — a write that merely leaves the existing lock in
      // place doesn't count).
      function holdsLock() {
        return !lockLive(resource.data.get('lock', null))
          || (request.resource.data.get('lock', null) != null
            && resource.data.lock.sessionId == request.resource.data.lock.sessionId
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['lock']));
      }

      // A write that only touches the lock: claiming, heartbeats, release,
      // take-over. Allowed for anyone who may edit — last write wins, and the
      // session that lost the lock flips read-only via its live snapshot.
      function lockOnly() {
        return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['lock']);
      }

      // Does this write change actual content (vs. metadata like folderId,
      // shared, editableByLink — owner-only chores that don't need the lock)?
      function touchesContent() {
        return request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['title', 'annotations', 'source']);
      }

      // Shared docs (view or edit links) are fetchable by id by anyone
      // holding the link; owners can always fetch their own. (`get(...)`
      // accessors: docs saved before link editing existed lack the
      // `editableByLink` key, and a missing key would error, not miss.)
      //
      // A signed-in user may also get a doc that doesn't exist yet: a
      // brand-new project's edit-lock subscription starts before the first
      // save creates the doc (see lib/editLock.ts), and a denial here would
      // read as "sharing revoked" and deadlock the new track read-only.
      // (Doc ids are unguessable, so existence probing gains nothing.)
      allow get: if (resource == null && request.auth != null)
        || resource.data.shared == true
        || resource.data.get('editableByLink', false) == true
        || (request.auth != null && resource.data.ownerId == request.auth.uid);

      allow list: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;

      allow update: if request.auth != null && (
        // Owner: anything except reassigning ownerId — but content edits
        // still respect a live lock held by another session.
        (resource.data.ownerId == request.auth.uid
          && request.resource.data.ownerId == request.auth.uid
          && (lockOnly() || !touchesContent() || holdsLock()))
        ||
        // Link editors: any signed-in user once the owner turns on link
        // editing. Content + the lock only — never permissions, ownership,
        // the source, or folders — and only while holding the lock.
        (resource.data.get('editableByLink', false) == true
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['title', 'annotations', 'updatedAt', 'lock'])
          && (lockOnly() || holdsLock()))
      );

      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }

    // Home-page folders are private to their owner — unlike projects there is
    // no share-by-link exception. Membership lives on each project's
    // `folderId`, so these docs are just names.
    match /folders/{folderId} {
      allow get, list: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;

      // Owner can rename/delete; ownerId can never be reassigned.
      allow update: if request.auth != null
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == request.auth.uid;

      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }
  }
}

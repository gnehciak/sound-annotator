# Firebase web-app config — copy this file to `.env.local` and paste your values.
# Find them in the Firebase console: Project settings → your Web app → "SDK setup
# and configuration" → Config. Restart `npm run dev` after editing.
#
# These are NOT secrets (they ship in the client bundle). Access is controlled by
# Firestore/Storage security rules and authorized domains, not by hiding these.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

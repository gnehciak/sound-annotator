# Backend config — everything is provisioned through the linked Vercel project
# (Neon Postgres, Clerk auth, Vercel Blob). Don't fill this in by hand: run
#
#   vercel env pull
#
# to sync `.env.local`, then restart the dev server. Server-side vars
# (DATABASE_URL, CLERK_SECRET_KEY, BLOB_READ_WRITE_TOKEN) are consumed by the
# /api functions; only VITE_-prefixed vars ship in the client bundle.

# Clerk publishable key (client, safe to expose — access is controlled by the
# API's session verification, not by hiding this).
VITE_CLERK_PUBLISHABLE_KEY=

# Server-side (used by /api functions; via `vercel env pull` or `vercel dev`):
# DATABASE_URL=            Neon Postgres (pooled)
# CLERK_SECRET_KEY=        Clerk backend key
# CLERK_PUBLISHABLE_KEY=   Clerk publishable key (server-side copy)
# BLOB_READ_WRITE_TOKEN=   Vercel Blob store token
